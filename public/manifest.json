{
  "manifest_version": 3,
  "name": "Seat Tracker",
  "version": "1.0.0",
  "description": "Real-time seat availability for BookMyShow & District",
  "permissions": ["cookies", "tabs"],
  "host_permissions": [
    "https://in.bookmyshow.com/*",
    "https://www.district.in/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Seat Tracker"
  }
}
